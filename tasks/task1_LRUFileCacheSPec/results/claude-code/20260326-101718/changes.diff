index 0000000..75c75e0
--- /dev/null
+++ b/Sources/LRUFileCache/AtomicWriter.swift
@@ -0,0 +1,50 @@
+import Foundation
+
+enum AtomicWriter {
+    /// Writes `data` to `destination` atomically.
+    ///
+    /// Strategy:
+    /// 1. Write to a UUID-named temp file in NSTemporaryDirectory (same APFS volume → rename is O(1))
+    /// 2. Set the requested data-protection class on the temp file
+    /// 3. Replace the destination with the temp file atomically via replaceItem(at:withItemAt:)
+    ///
+    /// - Throws: `CacheError.writeFailure` wrapping any underlying filesystem error.
+    static func write(
+        _ data: Data,
+        to destination: URL,
+        protectionClass: FileProtectionType
+    ) throws {
+        let fm = FileManager.default
+        let tmpURL = fm.temporaryDirectory
+            .appendingPathComponent(UUID().uuidString + ".tmp")
+
+        do {
+            try data.write(to: tmpURL, options: .atomic)
+        } catch {
+            throw CacheError.writeFailure(underlying: error)
+        }
+
+        do {
+            try fm.setAttributes(
+                [.protectionKey: protectionClass],
+                ofItemAtPath: tmpURL.path
+            )
+        } catch {
+            try? fm.removeItem(at: tmpURL)
+            throw CacheError.writeFailure(underlying: error)
+        }
+
+        do {
+            _ = try fm.replaceItemAt(destination, withItemAt: tmpURL)
+        } catch {
+            // replaceItemAt fails if destination's parent doesn't exist;
+            // fall back to moveItem for the first-write case (destination absent).
+            do {
+                try fm.moveItem(at: tmpURL, to: destination)
+            } catch let moveError {
+                try? fm.removeItem(at: tmpURL)
+                throw CacheError.writeFailure(underlying: moveError)
+            }
+        }
+    }
+}
