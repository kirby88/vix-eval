+import Foundation
+
+public struct CacheConfiguration: Sendable {
+    public var name: String
+    /// Maximum number of entries. 0 means unlimited.
+    public var maxEntryCount: Int
+    /// Maximum total payload bytes. 0 means unlimited.
+    public var maxTotalBytes: Int
+    public var evictionDebounceInterval: Duration
+    public var dataProtectionClass: FileProtectionType
+
+    /// Overrides the base directory used for the cache. Defaults to NSCachesDirectory.
+    /// Intended for testing only.
+    public var _baseURL: URL?
+
+    public init(
+        name: String,
+        maxEntryCount: Int = 1000,
+        maxTotalBytes: Int = 50 * 1024 * 1024,
+        evictionDebounceInterval: Duration = .seconds(2),
+        dataProtectionClass: FileProtectionType = .completeUntilFirstUserAuthentication,
+        _baseURL: URL? = nil
+    ) {
+        self.name = name
+        self.maxEntryCount = maxEntryCount
+        self.maxTotalBytes = maxTotalBytes
+        self.evictionDebounceInterval = evictionDebounceInterval
+        self.dataProtectionClass = dataProtectionClass
+        self._baseURL = _baseURL
+    }
+}
