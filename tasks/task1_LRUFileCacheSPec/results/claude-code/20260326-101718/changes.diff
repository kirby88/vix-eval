--- /dev/null
+++ b/Sources/LRUFileCache/Debouncer.swift
@@ -0,0 +1,32 @@
+import Foundation
+
+/// Debounces an async action: each call to `schedule` cancels any pending
+/// invocation and arms a new one that fires after `interval`.
+actor Debouncer {
+    private let interval: Duration
+    private var pendingTask: Task<Void, Never>?
+
+    init(interval: Duration) {
+        self.interval = interval
+    }
+
+    /// Schedule `action` to run after the debounce interval.
+    /// Any previously scheduled (but not yet fired) action is cancelled.
+    func schedule(_ action: @Sendable @escaping () async -> Void) {
+        pendingTask?.cancel()
+        pendingTask = Task { [interval] in
+            do {
+                try await Task.sleep(for: interval)
+                await action()
+            } catch {
+                // Task.CancellationError — expected on reschedule, ignore.
+            }
+        }
+    }
+
+    /// Cancel any pending action without firing it.
+    func flush() {
+        pendingTask?.cancel()
+        pendingTask = nil
+    }
+}
diff --git a/Sources/LRUFileCache/LRUFileCache.swift b/Sources/LRUFileCache/LRUFileCache.swift
new file mode 100644
index 0000000..7b3fc5e
--- /dev/null
+++ b/Sources/LRUFileCache/LRUFileCache.swift
@@ -0,0 +1,208 @@
+import Foundation
+
+/// A disk-backed LRU cache for arbitrary `Data` payloads.
+///
+/// - Multiple independent named instances are supported; each uses its own
+///   subdirectory under `NSCachesDirectory` (or a caller-supplied base URL).
+/// - All public methods are `async` and safe to call from any Swift concurrency context.
+/// - Eviction runs asynchronously and never blocks reads or writes.
+/// - The index is persisted to disk and survives process restarts.
+public actor LRUFileCache {
+
+    // MARK: - State
+
+    private let configuration: CacheConfiguration
+    private let cacheDirectoryURL: URL
+    private let indexURL: URL
+    private var index: CacheIndex
+    private let indexDebouncer: Debouncer
+
+    // MARK: - Init
+
+    /// Creates (or reopens) a named cache with the given configuration.
+    ///
+    /// The index is loaded from disk asynchronously; on corruption it degrades
+    /// silently to an empty cache. No blocking I/O occurs on the caller's hot path.
+    public init(configuration: CacheConfiguration) async {
+        self.configuration = configuration
+
+        let base: URL
+        if let override = configuration._baseURL {
+            base = override
+        } else {
+            base = FileManager.default.urls(for: .cachesDirectory, in: .userDomainMask)[0]
+        }
+        let cacheDir = base.appendingPathComponent(configuration.name, isDirectory: true)
+        self.cacheDirectoryURL = cacheDir
+        self.indexURL = cacheDir.appendingPathComponent("index.json")
+        self.indexDebouncer = Debouncer(interval: configuration.evictionDebounceInterval)
+
+        // Load index; degrade gracefully on any failure.
+        if let data = try? Data(contentsOf: indexURL),
+           let decoded = try? JSONDecoder.cacheIndex.decode(CacheIndex.self, from: data) {
+            self.index = decoded
+        } else {
+            self.index = CacheIndex()
+        }
+    }
+
+    // MARK: - Public API
+
+    /// Insert a new entry or replace an existing one.
+    public func add(key: String, data: Data) async throws {
+        try await upsert(key: key, data: data, requireExisting: false)
+    }
+
+    /// Alias for `add`; signals update intent to the caller.
+    public func update(key: String, data: Data) async throws {
+        try await upsert(key: key, data: data, requireExisting: false)
+    }
+
+    /// Replace the payload for an existing key.
+    /// - Throws: `CacheError.keyNotFound` if the key is not present.
+    public func modify(key: String, data: Data) async throws {
+        try await upsert(key: key, data: data, requireExisting: true)
+    }
+
+    /// Return the payload for `key` and bump its last-accessed date.
+    /// Returns `nil` if the key is absent or its backing file is missing
+    /// (in the latter case the index is self-healed).
+    public func get(key: String) async throws -> Data? {
+        guard var entry = index.entries[key] else { return nil }
+
+        let fileURL = cacheDirectoryURL.appendingPathComponent(entry.filename)
+        guard let data = try? Data(contentsOf: fileURL) else {
+            // File missing on disk — self-heal the index.
+            index.entries.removeValue(forKey: key)
+            let capturedSelf = self
+            await indexDebouncer.schedule { await capturedSelf.persistIndex() }
+            return nil
+        }
+
+        entry.lastAccessedAt = Date()
+        index.entries[key] = entry
+
+        let capturedSelf = self
+        await indexDebouncer.schedule { await capturedSelf.persistIndex() }
+
+        return data
+    }
+
+    /// Update the last-accessed date for `key` without reading the payload.
+    /// - Throws: `CacheError.keyNotFound` if the key is not present.
+    public func promote(key: String) async throws {
+        guard var entry = index.entries[key] else {
+            throw CacheError.keyNotFound(key)
+        }
+        entry.lastAccessedAt = Date()
+        index.entries[key] = entry
+
+        let capturedSelf = self
+        await indexDebouncer.schedule { await capturedSelf.persistIndex() }
+    }
+
+    // MARK: - Private helpers
+
+    private func upsert(key: String, data: Data, requireExisting: Bool) async throws {
+        if requireExisting, index.entries[key] == nil {
+            throw CacheError.keyNotFound(key)
+        }
+
+        try ensureCacheDirectoryExists()
+
+        let filename: String
+        if let existing = index.entries[key] {
+            filename = existing.filename
+        } else {
+            filename = UUID().uuidString + ".bin"
+        }
+
+        let destination = cacheDirectoryURL.appendingPathComponent(filename)
+        try AtomicWriter.write(data, to: destination, protectionClass: configuration.dataProtectionClass)
+
+        let now = Date()
+        let entry = CacheEntry(
+            key: key,
+            filename: filename,
+            byteCount: data.count,
+            lastAccessedAt: now,
+            createdAt: index.entries[key]?.createdAt ?? now
+        )
+        index.entries[key] = entry
+
+        persistIndex()
+        await indexDebouncer.flush()
+        evictIfNeeded()
+    }
+
+    /// Recreates the cache directory if it has been deleted externally.
+    private func ensureCacheDirectoryExists() throws {
+        let fm = FileManager.default
+        guard !fm.fileExists(atPath: cacheDirectoryURL.path) else { return }
+        do {
+            try fm.createDirectory(
+                at: cacheDirectoryURL,
+                withIntermediateDirectories: true,
+                attributes: [.protectionKey: configuration.dataProtectionClass]
+            )
+        } catch {
+            throw CacheError.directoryCreationFailure(underlying: error)
+        }
+    }
+
+    /// Writes the current in-memory index to disk immediately.
+    /// Errors are swallowed; the in-memory index remains authoritative.
+    private func persistIndex() {
+        guard let data = try? JSONEncoder.cacheIndex.encode(index) else { return }
+        try? AtomicWriter.write(data, to: indexURL, protectionClass: configuration.dataProtectionClass)
+    }
+
+    /// Selects and evicts entries that push the cache over its configured limits.
+    ///
+    /// Victim selection happens synchronously (in-actor) for correctness.
+    /// File moves are dispatched to a background Task so they never block callers.
+    private func evictIfNeeded() {
+        let effectiveMaxCount = configuration.maxEntryCount == 0 ? Int.max : configuration.maxEntryCount
+        let effectiveMaxBytes = configuration.maxTotalBytes == 0 ? Int.max : configuration.maxTotalBytes
+
+        guard index.entries.count > effectiveMaxCount
+                || index.totalByteCount > effectiveMaxBytes
+        else { return }
+
+        let sorted = index.lruSorted()
+        var victims: [CacheEntry] = []
+        var remainingCount = index.entries.count
+        var remainingBytes = index.totalByteCount
+
+        for entry in sorted {
+            guard remainingCount > effectiveMaxCount || remainingBytes > effectiveMaxBytes else { break }
+            victims.append(entry)
+            remainingCount -= 1
+            remainingBytes -= entry.byteCount
+        }
+
+        guard !victims.isEmpty else { return }
+
+        for victim in victims {
+            index.entries.removeValue(forKey: victim.key)
+        }
+
+        persistIndex()
+        // indexDebouncer.flush() is not called here intentionally: a mutation
+        // persist just happened, and flushing the debouncer is only needed to
+        // prevent a stale debounced write from overwriting a fresher one.
+        // Since eviction always follows a mutation (which already flushed),
+        // no stale task can exist at this point.
+
+        let srcDir = cacheDirectoryURL
+        Task(priority: .utility) {
+            let fm = FileManager.default
+            let tmp = fm.temporaryDirectory
+            for entry in victims {
+                let src = srcDir.appendingPathComponent(entry.filename)
+                let dst = tmp.appendingPathComponent(UUID().uuidString + "-evicted.bin")
+                try? fm.moveItem(at: src, to: dst)
+            }
+        }
+    }
+}
