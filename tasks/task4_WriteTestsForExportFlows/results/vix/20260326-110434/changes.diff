+
+class TestSummarizeUsage:
+    def _make_agent_structure(self, tmp_path, agent_name, steps):
+        """Create agent directory structure.
+        steps: list of lists of usage dicts (steps[step_idx][req_idx])
+        """
+        agent_dir = tmp_path / agent_name
+        agent_dir.mkdir(parents=True)
+        for step_num, requests in enumerate(steps, start=1):
+            step_dir = agent_dir / str(step_num)
+            step_dir.mkdir()
+            for req_num, usage in enumerate(requests, start=1):
+                req_dir = step_dir / str(req_num)
+                req_dir.mkdir()
+                write_usage_json(str(req_dir), usage)
+
+    def _base_usage(self, model="claude-sonnet-4-5", input_t=100, out_t=50,
+                    rs=1000.0, re=1002.0):
+        return {
+            "model": model,
+            "cost": {
+                "input": {"tokens": input_t, "dollars": input_t * 3e-6},
+                "cache_write": {"tokens": 0, "dollars": 0.0},
+                "cache_read": {"tokens": 0, "dollars": 0.0},
+                "output": {"tokens": out_t, "dollars": out_t * 15e-6},
+                "total": {"tokens": input_t + out_t, "dollars": (input_t * 3e-6) + (out_t * 15e-6)},
+            },
+            "timing": {"request_start": rs, "response_end": re, "duration_ms": round((re - rs) * 1000)},
+        }
+
+    def test_skips_dirs_without_numbered_subdirs(self, tmp_path):
+        no_numbered = tmp_path / "agent_no_steps"
+        no_numbered.mkdir()
+        (no_numbered / "some_file.txt").write_text("data")
+        summarize_usage(str(tmp_path))
+        assert not (no_numbered / "usage.json").exists()
+
+    def test_creates_usage_json_summary(self, tmp_path):
+        self._make_agent_structure(tmp_path, "vix", [[self._base_usage()]])
+        summarize_usage(str(tmp_path))
+        summary_file = tmp_path / "vix" / "usage.json"
+        assert summary_file.exists()
+
+    def test_by_model_bucketing(self, tmp_path):
+        usage1 = self._base_usage(model="claude-sonnet-4-5")
+        usage2 = self._base_usage(model="claude-haiku-3-5", input_t=200, out_t=100)
+        self._make_agent_structure(tmp_path, "vix", [[usage1], [usage2]])
+        summarize_usage(str(tmp_path))
+        data = json.loads((tmp_path / "vix" / "usage.json").read_text())
+        assert "claude-sonnet-4-5" in data["by_model"]
+        assert "claude-haiku-3-5" in data["by_model"]
+
+    def test_by_step_bucketing(self, tmp_path):
