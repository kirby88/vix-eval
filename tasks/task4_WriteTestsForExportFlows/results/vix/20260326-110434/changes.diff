+    def test_finalize_timing_wall_clock(self, tmp_path):
+        u1 = self._base_usage(rs=1000.0, re=1005.0)
+        u2 = self._base_usage(rs=1003.0, re=1010.0)
+        self._make_agent_structure(tmp_path, "vix", [[u1, u2]])
+        summarize_usage(str(tmp_path))
+        data = json.loads((tmp_path / "vix" / "usage.json").read_text())
