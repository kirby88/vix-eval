+class TestExtractStopReason:
+    def test_sse_without_spaces(self):
+        response = 'data: {"type":"message_delta","delta":{"stop_reason":"end_turn"}}'
+        assert extract_stop_reason(response) == "end_turn"
+
+    def test_sse_with_spaces(self):
+        response = 'data: {"type": "message_delta", "delta": {"stop_reason": "tool_use"}}'
+        assert extract_stop_reason(response) == "tool_use"
+
+    def test_sse_null_stop_reason_then_valid(self):
+        response = (
+            'data: {"type":"message_delta","delta":{"stop_reason":null}}\n'
+            'data: {"type":"message_delta","delta":{"stop_reason":"end_turn"}}'
+        )
+        assert extract_stop_reason(response) == "end_turn"
+
+    def test_non_streaming_json_fallback(self):
+        msg = json.dumps({"type": "message", "stop_reason": "end_turn", "content": []})
+        assert extract_stop_reason(msg) == "end_turn"
+
+    def test_invalid_json_in_data_line_skipped(self):
+        response = (
+            'data: {invalid json}\n'
+            'data: {"type": "message_delta", "delta": {"stop_reason": "end_turn"}}'
+        )
+        assert extract_stop_reason(response) == "end_turn"
+
+    def test_no_relevant_data_returns_unknown(self):
+        assert extract_stop_reason("no data here") == "unknown"
+
+    def test_empty_string_returns_unknown(self):
+        assert extract_stop_reason("") == "unknown"
+
+    def test_sse_takes_priority_over_non_streaming(self):
+        sse_line = 'data: {"type":"message_delta","delta":{"stop_reason":"tool_use"}}'
+        fallback = json.dumps({"type": "message", "stop_reason": "end_turn"})
+        response = sse_line + "\n" + fallback
+        assert extract_stop_reason(response) == "tool_use"
+
+    def test_invalid_json_in_sse_message_delta_skipped(self):
+        # Hits the except JSONDecodeError at line 156-157 in extract_stop_reason
+        response = 'data: {"type":"message_delta","delta":{invalid}}'
+        # This parses as having message_delta type check but fails json.loads → skipped
+        # Then falls through to non-streaming fallback → unknown
+        assert extract_stop_reason(response) == "unknown"
+
+    def test_non_streaming_json_fallback_invalid_line_skipped(self):
+        # Hits the except JSONDecodeError at lines 170-171
+        response = '{"invalid json here'
+        assert extract_stop_reason(response) == "unknown"
+
