+class TestFormatHeaders:
+    def _make_headers(self, pairs):
+        """Create mitmproxy Headers from list of (str, str) pairs."""
+        fields = [(k.encode(), v.encode()) for k, v in pairs]
+        return Headers(fields=fields)
+
+    def test_api_key_redacted(self):
+        h = self._make_headers([("x-api-key", "my-secret")])
+        result = format_headers(h)
+        assert "[REDACTED]" in result
+        assert "my-secret" not in result
+
+    def test_authorization_redacted(self):
+        h = self._make_headers([("authorization", "Bearer token123")])
+        result = format_headers(h)
+        assert "[REDACTED]" in result
+        assert "token123" not in result
+
+    def test_content_type_passes_through(self):
+        h = self._make_headers([("content-type", "application/json")])
+        result = format_headers(h)
+        assert "application/json" in result
+
+    def test_multiple_headers_joined_newlines(self):
+        h = self._make_headers([
+            ("content-type", "application/json"),
+            ("x-request-id", "abc123"),
+        ])
+        result = format_headers(h)
+        lines = result.split("\n")
+        assert len(lines) == 2
+
+    def test_uppercase_api_key_still_redacted(self):
+        h = self._make_headers([("X-API-KEY", "secret")])
+        result = format_headers(h)
+        assert "[REDACTED]" in result
+        assert "secret" not in result
+
+    def test_mixed_sensitive_and_safe(self):
+        h = self._make_headers([
+            ("x-api-key", "secret"),
+            ("content-type", "application/json"),
+        ])
+        result = format_headers(h)
+        assert "[REDACTED]" in result
+        assert "application/json" in result
