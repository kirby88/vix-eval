+# TestSystemPromptHash
+# ---------------------------------------------------------------------------
+
+class TestSystemPromptHash:
+    def _body(self, system_blocks):
+        return {"system": system_blocks, "messages": []}
+
+    def test_cc_agent_uses_index_2(self):
+        blocks = [
+            {"type": "text", "text": "block0"},
+            {"type": "text", "text": "block1"},
+            {"type": "text", "text": "block2_target"},
+        ]
+        h = _system_prompt_hash(self._body(blocks), "cc")
+        expected = hashlib.sha256("block2_target".encode()).hexdigest()[:12]
+        assert h == expected
+
+    def test_vix_agent_uses_index_0(self):
+        blocks = [{"type": "text", "text": "vix_block"}]
+        h = _system_prompt_hash(self._body(blocks), "vix")
+        expected = hashlib.sha256("vix_block".encode()).hexdigest()[:12]
+        assert h == expected
+
+    def test_unknown_agent_defaults_to_index_0(self):
+        blocks = [{"type": "text", "text": "default_block"}]
+        h = _system_prompt_hash(self._body(blocks), "unknown_agent")
+        expected = hashlib.sha256("default_block".encode()).hexdigest()[:12]
+        assert h == expected
+
+    def test_missing_system_key_returns_none(self):
+        assert _system_prompt_hash({"messages": []}, "cc") is None
+
+    def test_empty_system_list_returns_none(self):
+        assert _system_prompt_hash({"system": []}, "cc") is None
+
+    def test_index_out_of_bounds_returns_none(self):
+        # cc uses index 2, but only 1 block
+        blocks = [{"type": "text", "text": "only_one"}]
+        assert _system_prompt_hash(self._body(blocks), "cc") is None
+
+    def test_empty_text_returns_none(self):
+        blocks = [{"type": "text", "text": ""}]
+        assert _system_prompt_hash(self._body(blocks), "vix") is None
+
+    def test_returns_12_char_hex(self):
+        blocks = [{"type": "text", "text": "hello"}]
+        h = _system_prompt_hash(self._body(blocks), "vix")
+        assert len(h) == 12
+        assert all(c in "0123456789abcdef" for c in h)
+
+    def test_deterministic(self):
+        blocks = [{"type": "text", "text": "consistent"}]
+        body = self._body(blocks)
+        h1 = _system_prompt_hash(body, "vix")
+        h2 = _system_prompt_hash(body, "vix")
+        assert h1 == h2
+
