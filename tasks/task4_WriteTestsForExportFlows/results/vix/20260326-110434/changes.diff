+class TestAttributeTokens:
+    def _make_usage(self, input_t=100, cw_t=50, cr_t=200, out_t=80, out_d=0.002):
+        return {
+            "cost": {
+                "input": {"tokens": input_t, "dollars": input_t * 3e-6},
+                "cache_write": {"tokens": cw_t, "dollars": cw_t * 3.75e-6},
+                "cache_read": {"tokens": cr_t, "dollars": cr_t * 0.30e-6},
+                "output": {"tokens": out_t, "dollars": out_d},
+            }
+        }
+
+    def _make_pricing(self):
+        return MODEL_PRICING["claude-sonnet-4-5"]
+
+    def test_full_case(self):
+        input_sources = {
+            "total_chars": 1000,
+            "tool_results": {"Read": {"cache_write_chars": 400, "cache_read_chars": 100}},
+            "tool_calls": {"bash": {"cache_write_chars": 200, "cache_read_chars": 100}},
+        }
+        output_sources = {"llm_text": 300, "tool_calls": {"bash": 200}}
+        usage = self._make_usage()
+        pricing = self._make_pricing()
+        by_source = attribute_tokens(input_sources, output_sources, usage, pricing)
+        assert "tool_results" in by_source["input"]
+        assert "tool_calls" in by_source["input"]
+        assert "llm_text" in by_source["output"]
+        assert "tool_calls" in by_source["output"]
+
+    def test_zero_total_chars_skips_input(self):
+        input_sources = {"total_chars": 0, "tool_results": {"Read": {"cache_write_chars": 100, "cache_read_chars": 0}}}
+        output_sources = {"llm_text": 100, "tool_calls": {}}
+        by_source = attribute_tokens(input_sources, output_sources, self._make_usage(), self._make_pricing())
+        assert by_source["input"] == {}
+
+    def test_zero_input_tokens_skips_input(self):
+        input_sources = {"total_chars": 1000, "tool_results": {"Read": {"cache_write_chars": 100, "cache_read_chars": 0}}}
+        output_sources = {"llm_text": 100, "tool_calls": {}}
+        usage = {"cost": {"input": {"tokens": 0}, "cache_write": {"tokens": 0}, "cache_read": {"tokens": 0}, "output": {"tokens": 50, "dollars": 0.001}}}
+        by_source = attribute_tokens(input_sources, output_sources, usage, self._make_pricing())
+        assert by_source["input"] == {}
+
+    def test_none_pricing_skips_input(self):
+        input_sources = {"total_chars": 1000, "tool_results": {"Read": {"cache_write_chars": 100, "cache_read_chars": 0}}}
+        output_sources = {"llm_text": 100, "tool_calls": {}}
+        by_source = attribute_tokens(input_sources, output_sources, self._make_usage(), None)
+        assert by_source["input"] == {}
+
+    def test_zero_total_output_chars_skips_output(self):
+        input_sources = {"total_chars": 1000, "tool_results": {}}
+        output_sources = {"llm_text": 0, "tool_calls": {}}
+        by_source = attribute_tokens(input_sources, output_sources, self._make_usage(), self._make_pricing())
+        assert by_source["output"] == {}
+
+    def test_proportional_output_math(self):
+        input_sources = {"total_chars": 1000, "tool_results": {}}
