+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+def make_sse_response(events):
+    """Build a raw response_raw.txt string from a list of SSE event dicts."""
+    lines = ["200 OK", "", "content-type: text/event-stream", ""]
+    for event in events:
+        lines.append(f"data: {json.dumps(event)}")
+    return "\n".join(lines)
+
+
+def write_response_raw(path, content):
+    """Write content to path/response_raw.txt."""
+    with open(os.path.join(path, "response_raw.txt"), "w") as f:
+        f.write(content)
+
+
+def write_request_json(path, body):
+    """Write body dict as JSON to path/request.json."""
+    with open(os.path.join(path, "request.json"), "w") as f:
+        json.dump(body, f, indent=2)
+        f.write("\n")
+
+
+def write_usage_json(path, usage):
+    """Write usage dict as JSON to path/usage.json."""
+    with open(os.path.join(path, "usage.json"), "w") as f:
+        json.dump(usage, f, indent=2)
+        f.write("\n")
+
+
+def make_flow(method="POST", url="https://api.anthropic.com/v1/messages",
+              body=None, response_body=None, api_key=None):
+    """Create a mitmproxy HTTPFlow with optional body and response body."""
+    f = tflow.tflow(resp=True)
+    f.request.method = method
+    f.request.url = url
+    if body is not None:
+        if isinstance(body, dict):
+            f.request.content = json.dumps(body).encode()
+        else:
+            f.request.content = body if isinstance(body, bytes) else body.encode()
+    if api_key:
+        f.request.headers["x-api-key"] = api_key
+    if response_body is not None:
+        if isinstance(response_body, str):
+            f.response.content = response_body.encode()
+        else:
+            f.response.content = response_body
+    return f
+
+
+def write_flow_file(path, flows):
+    """Write a list of mitmproxy flows to a .flow file at the given path."""
+    with open(path, "wb") as f:
+        writer = FlowWriter(f)
+        for flow in flows:
+            writer.add(flow)
+
