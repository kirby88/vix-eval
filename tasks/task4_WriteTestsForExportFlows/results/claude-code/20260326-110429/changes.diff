+class TestExtractStopReason:
+    def test_sse_end_turn(self):
+        content = build_sse_response(stop_reason="end_turn")
+        assert extract_stop_reason(content) == "end_turn"
+
+    def test_sse_tool_use(self):
+        content = build_sse_response(stop_reason="tool_use")
+        assert extract_stop_reason(content) == "tool_use"
+
+    def test_sse_max_tokens(self):
+        content = build_sse_response(stop_reason="max_tokens")
+        assert extract_stop_reason(content) == "max_tokens"
+
+    def test_sse_compact_type_recognized(self):
+        # compact form: no space after colon
+        payload = '{"type":"message_delta","delta":{"stop_reason":"end_turn"},"usage":{}}'
+        content = f"data: {payload}\n"
+        assert extract_stop_reason(content) == "end_turn"
+
+    def test_sse_spaced_type_recognized(self):
+        # spaced form
+        payload = '{"type": "message_delta", "delta": {"stop_reason": "end_turn"}, "usage": {}}'
+        content = f"data: {payload}\n"
+        assert extract_stop_reason(content) == "end_turn"
+
+    def test_sse_bad_json_skipped(self):
+        bad = "data: {invalid json\n"
+        good = build_sse_response(stop_reason="end_turn")
+        assert extract_stop_reason(bad + good) == "end_turn"
+
+    def test_sse_delta_missing_stop_reason(self):
+        # message_delta without stop_reason falls through
+        payload = json.dumps({"type": "message_delta", "delta": {}, "usage": {}})
+        content = f"data: {payload}\n"
+        assert extract_stop_reason(content) == "unknown"
+
+    def test_non_streaming_json_message(self):
+        msg = json.dumps({"type": "message", "stop_reason": "max_tokens", "content": []})
+        content = f"HTTP/1.1 200 OK\n\n{msg}\n"
+        assert extract_stop_reason(content) == "max_tokens"
+
+    def test_non_streaming_last_json_wins(self):
+        # reversed scan: last valid message type wins
+        msg1 = json.dumps({"type": "message", "stop_reason": "tool_use", "content": []})
+        msg2 = json.dumps({"type": "message", "stop_reason": "end_turn", "content": []})
+        content = f"{msg1}\n{msg2}\n"
+        # reversed scan hits msg2 first → "end_turn"
+        assert extract_stop_reason(content) == "end_turn"
+
+    def test_non_streaming_bad_json_skipped(self):
+        bad = "{not json}"
+        good = json.dumps({"type": "message", "stop_reason": "end_turn", "content": []})
+        content = f"{bad}\n{good}\n"
+        assert extract_stop_reason(content) == "end_turn"
+
+    def test_no_relevant_content_returns_unknown(self):
+        assert extract_stop_reason("HTTP/1.1 200 OK\n\nsome random text") == "unknown"
+
+    def test_empty_string_returns_unknown(self):
+        assert extract_stop_reason("") == "unknown"
