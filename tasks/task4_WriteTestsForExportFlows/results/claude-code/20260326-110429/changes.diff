+class TestCountWhitespaceStats:
+    def test_empty_string(self):
+        r = count_whitespace_stats("")
+        assert r == {"line_returns_count": 0, "unnecessary_space_count": 0, "total_chars": 0}
+
+    def test_single_newline(self):
+        r = count_whitespace_stats("\n")
+        assert r["line_returns_count"] == 1
+        assert r["unnecessary_space_count"] == 0
+        assert r["total_chars"] == 1
+
+    def test_multiple_newlines(self):
+        r = count_whitespace_stats("\n\n\n")
+        assert r["line_returns_count"] == 3
+        assert r["total_chars"] == 3
+
+    def test_two_spaces_count_one(self):
+        r = count_whitespace_stats("  ")
+        assert r["unnecessary_space_count"] == 1  # len(2) - 1
+
+    def test_three_spaces_count_two(self):
+        r = count_whitespace_stats("   ")
+        assert r["unnecessary_space_count"] == 2  # len(3) - 1
+
+    def test_single_spaces_not_counted(self):
+        r = count_whitespace_stats("a b c d")
+        assert r["unnecessary_space_count"] == 0
+
+    def test_multiple_separate_runs_summed(self):
+        # "a  b   c" → run of 2 (1) + run of 3 (2) = 3
+        r = count_whitespace_stats("a  b   c")
+        assert r["unnecessary_space_count"] == 3
+
+    def test_mixed_newlines_and_spaces(self):
+        r = count_whitespace_stats("a  b\nc   d")
+        assert r["line_returns_count"] == 1
+        assert r["unnecessary_space_count"] == 3  # 1 + 2
+
+    def test_total_chars_counts_all(self):
+        text = "hello\n  world"
+        r = count_whitespace_stats(text)
+        assert r["total_chars"] == len(text)
+
+    def test_no_whitespace(self):
+        r = count_whitespace_stats("abcdef")
+        assert r == {"line_returns_count": 0, "unnecessary_space_count": 0, "total_chars": 6}
+
