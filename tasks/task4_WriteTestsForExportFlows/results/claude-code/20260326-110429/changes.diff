+# TestAttributeTokens
+# ---------------------------------------------------------------------------
+
+SONNET_PRICING = MODEL_PRICING["claude-sonnet-4-5"]
+
+
+class TestAttributeTokens:
+    def _usage_with_cost(self, inp_tokens=1000, cw_tokens=0, cr_tokens=0, out_tokens=500):
+        pricing = SONNET_PRICING
+        return {
+            "cost": {
+                "input": {"tokens": inp_tokens, "dollars": inp_tokens * pricing["input"]},
+                "cache_write": {"tokens": cw_tokens, "dollars": cw_tokens * pricing["cache_write"]},
+                "cache_read": {"tokens": cr_tokens, "dollars": cr_tokens * pricing["cache_read"]},
+                "output": {
+                    "tokens": out_tokens,
+                    "dollars": out_tokens * pricing["output"],
+                },
+            }
+        }
+
+    def test_result_has_input_and_output_keys(self):
+        input_sources = {
+            "total_chars": 1000,
+            "tool_results": {"Read": {"cache_write_chars": 100, "cache_read_chars": 200}},
+            "tool_calls": {},
+        }
+        output_sources = {"llm_text": 300, "tool_calls": {}}
+        usage = self._usage_with_cost()
+        result = attribute_tokens(input_sources, output_sources, usage, SONNET_PRICING)
+        assert "input" in result
+        assert "output" in result
+
+    def test_input_tool_results_attributed(self):
+        input_sources = {
+            "total_chars": 1000,
+            "tool_results": {"Read": {"cache_write_chars": 500, "cache_read_chars": 0}},
+            "tool_calls": {},
+        }
+        output_sources = {"llm_text": 100, "tool_calls": {}}
+        usage = self._usage_with_cost(inp_tokens=1000)
+        result = attribute_tokens(input_sources, output_sources, usage, SONNET_PRICING)
+        assert "tool_results" in result["input"]
+        assert "Read" in result["input"]["tool_results"]
+        entry = result["input"]["tool_results"]["Read"]
+        assert entry["tokens"] > 0
+        assert entry["chars"] == 500
+
+    def test_output_llm_text_proportional(self):
+        input_sources = {"total_chars": 100, "tool_results": {}, "tool_calls": {}}
+        output_sources = {"llm_text": 300, "tool_calls": {"Write": 200}}
+        usage = self._usage_with_cost(out_tokens=500)
+        result = attribute_tokens(input_sources, output_sources, usage, SONNET_PRICING)
+        llm = result["output"]["llm_text"]
+        # llm fraction = 300/500
+        assert llm["tokens"] == round(500 * (300 / 500))
+        assert llm["chars"] == 300
+
+    def test_output_tool_calls_total_entry(self):
+        input_sources = {"total_chars": 100, "tool_results": {}, "tool_calls": {}}
+        output_sources = {"llm_text": 200, "tool_calls": {"Write": 300}}
+        usage = self._usage_with_cost(out_tokens=500)
+        result = attribute_tokens(input_sources, output_sources, usage, SONNET_PRICING)
+        assert "__total" in result["output"]["tool_calls"]
+        assert "Write" in result["output"]["tool_calls"]
+
+    def test_zero_total_chars_skips_input(self):
+        input_sources = {
+            "total_chars": 0,
+            "tool_results": {"Read": {"cache_write_chars": 100, "cache_read_chars": 0}},
+            "tool_calls": {},
+        }
+        output_sources = {"llm_text": 100, "tool_calls": {}}
+        usage = self._usage_with_cost()
+        result = attribute_tokens(input_sources, output_sources, usage, SONNET_PRICING)
+        assert result["input"] == {}
+
+    def test_none_pricing_skips_input(self):
+        input_sources = {
+            "total_chars": 1000,
+            "tool_results": {"Read": {"cache_write_chars": 100, "cache_read_chars": 0}},
+            "tool_calls": {},
+        }
+        output_sources = {"llm_text": 100, "tool_calls": {}}
+        usage = self._usage_with_cost()
+        result = attribute_tokens(input_sources, output_sources, usage, None)
+        assert result["input"] == {}
+
+    def test_zero_output_chars_skips_output(self):
+        input_sources = {"total_chars": 100, "tool_results": {}, "tool_calls": {}}
+        output_sources = {"llm_text": 0, "tool_calls": {}}
+        usage = self._usage_with_cost(out_tokens=500)
+        result = attribute_tokens(input_sources, output_sources, usage, SONNET_PRICING)
+        assert result["output"] == {}
+
+    def test_zero_output_tokens_skips_output(self):
+        input_sources = {"total_chars": 100, "tool_results": {}, "tool_calls": {}}
+        output_sources = {"llm_text": 100, "tool_calls": {}}
+        usage = self._usage_with_cost(out_tokens=0)
+        result = attribute_tokens(input_sources, output_sources, usage, SONNET_PRICING)
+        assert result["output"] == {}
+
+    def test_each_entry_has_tokens_dollars_chars(self):
+        input_sources = {
+            "total_chars": 1000,
+            "tool_results": {"Read": {"cache_write_chars": 200, "cache_read_chars": 300}},
+            "tool_calls": {},
+        }
+        output_sources = {"llm_text": 200, "tool_calls": {}}
+        usage = self._usage_with_cost()
+        result = attribute_tokens(input_sources, output_sources, usage, SONNET_PRICING)
+        for key in ("tokens", "dollars", "chars"):
+            assert key in result["input"]["tool_results"]["Read"]
