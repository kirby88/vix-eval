+def _make_agent_dir(base, agent_name="vix", num_steps=1, num_requests=2, model="claude-sonnet-4-5"):
+    """Create a directory structure suitable for summarize_usage."""
+    agent_dir = base / agent_name
+    agent_dir.mkdir(parents=True, exist_ok=True)
+    pricing = MODEL_PRICING[model]
+    for step in range(1, num_steps + 1):
+        step_dir = agent_dir / str(step)
+        step_dir.mkdir(parents=True, exist_ok=True)
+        for req in range(1, num_requests + 1):
+            req_dir = step_dir / str(req)
+            req_dir.mkdir(parents=True, exist_ok=True)
+            usage = {
+                "model": model,
+                "cost": {
+                    "input": {"tokens": 100, "dollars": round(100 * pricing["input"], 6)},
+                    "cache_write": {"tokens": 0, "dollars": 0.0},
+                    "cache_read": {"tokens": 0, "dollars": 0.0},
+                    "output": {"tokens": 50, "dollars": round(50 * pricing["output"], 6)},
+                    "total": {"tokens": 150, "dollars": round(150 * pricing["input"], 6)},
+                },
+                "timing": {
+                    "request_start": 1000.0 + (step - 1) * 10 + req,
+                    "response_end": 1002.0 + (step - 1) * 10 + req,
+                    "duration_ms": 2000,
+                },
+            }
+            (req_dir / "usage.json").write_text(json.dumps(usage))
+    return agent_dir
+
