+class TestSystemPromptHash:
+    def test_cc_agent_uses_index_2(self):
+        system = [
+            {"type": "text", "text": "block0"},
+            {"type": "text", "text": "block1"},
+            {"type": "text", "text": "target"},
+        ]
+        body = {"system": system}
+        expected = hashlib.sha256(b"target").hexdigest()[:12]
+        assert _system_prompt_hash(body, "cc") == expected
+
+    def test_vix_agent_uses_index_0(self):
+        system = [{"type": "text", "text": "foo"}]
+        body = {"system": system}
+        expected = hashlib.sha256(b"foo").hexdigest()[:12]
+        assert _system_prompt_hash(body, "vix") == expected
+
+    def test_unknown_agent_uses_index_0(self):
+        system = [{"type": "text", "text": "bar"}]
+        body = {"system": system}
+        expected = hashlib.sha256(b"bar").hexdigest()[:12]
+        assert _system_prompt_hash(body, "other") == expected
+
+    def test_returns_12_char_hex(self):
+        system = [{"type": "text", "text": "hello"}]
+        body = {"system": system}
+        result = _system_prompt_hash(body, "vix")
+        assert len(result) == 12
+        assert re.match(r"^[0-9a-f]+$", result)
+
+    def test_no_system_key_returns_none(self):
+        assert _system_prompt_hash({}, "vix") is None
+
+    def test_empty_system_returns_none(self):
+        assert _system_prompt_hash({"system": []}, "vix") is None
+
+    def test_index_out_of_bounds_returns_none(self):
+        # cc uses index 2 but only 1 block
+        body = {"system": [{"type": "text", "text": "only one"}]}
+        assert _system_prompt_hash(body, "cc") is None
+
+    def test_empty_text_returns_none(self):
+        body = {"system": [{"type": "text", "text": ""}]}
+        assert _system_prompt_hash(body, "vix") is None
+
+    def test_missing_text_key_returns_none(self):
+        body = {"system": [{"type": "text"}]}  # no "text" key
+        assert _system_prompt_hash(body, "vix") is None
+
+    def test_deterministic(self):
+        body = {"system": [{"type": "text", "text": "same"}]}
+        r1 = _system_prompt_hash(body, "vix")
+        r2 = _system_prompt_hash(body, "vix")
+        assert r1 == r2
