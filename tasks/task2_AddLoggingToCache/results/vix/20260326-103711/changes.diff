+import Foundation
+
+// MARK: - Public types
+
+/// The outcome of a cache operation, recorded as a span attribute.
+public enum SpanOutcome: String {
+    case hit     = "hit"
+    case miss    = "miss"
+    case set     = "set"
+    case removed = "removed"
+    case evicted = "evicted"
+}
+
+/// A single unit of tracing work. Implementations must be reference types.
+public protocol TraceSpan: AnyObject {
+    func setAttribute(key: String, value: String)
+    func setAttribute(key: String, value: UInt)
+    func end()
+}
+
+/// Factory that creates spans. Implementations must be reference types.
+public protocol Tracer: AnyObject {
+    /// Start a child span under `context`, or a root span if context is nil.
+    func startSpan(named name: String, context: TraceContext?) -> TraceSpan
+}
+
+/// Lightweight value type that carries the current span across async boundaries.
+/// Capturing this by value in a closure before `DispatchQueue.async` prevents
+/// context leakage between concurrent, unrelated operations.
+public struct TraceContext {
+    public let span: TraceSpan
+    public init(span: TraceSpan) { self.span = span }
+}
+
+// MARK: - No-op implementations (internal)
+
+final class NoOpSpan: TraceSpan {
+    func setAttribute(key: String, value: String) {}
+    func setAttribute(key: String, value: UInt) {}
+    func end() {}
+}
+
+final class NoOpTracer: Tracer {
+    static let shared = NoOpTracer()
+    func startSpan(named name: String, context: TraceContext?) -> TraceSpan {
+        return NoOpSpan()
+    }
+}
+
+// MARK: - Span attribute key constants (internal)
+
+enum TraceAttribute {
+    static let cacheName = "cache.name"
+    static let cacheKey  = "cache.key"
+    static let outcome   = "cache.outcome"
+    static let byteSize  = "cache.byte_size"
+    static let layer     = "cache.layer"
+}
+
+// MARK: - Convenience helper (internal)
+
+/// Starts a span, runs `body`, ends the span, and returns the result.
+/// Use only for synchronous code paths where the span lifetime fits within one call frame.
+@discardableResult
+func _withSpan<R>(
+    tracer: Tracer,
+    named operationName: String,
+    context: TraceContext?,
+    body: (TraceSpan) -> R
+) -> R {
+    let span = tracer.startSpan(named: operationName, context: context)
+    let result = body(span)
+    span.end()
+    return result
+}
