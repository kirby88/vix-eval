+import Foundation
+
+// MARK: - Public tracing protocols and types
+
+/// Opaque carrier for a trace context. Declared as a class protocol so that
+/// closure captures copy the reference, not the value — each in-flight
+/// operation independently holds its own context without any shared mutable
+/// state. This is the primary mechanism that prevents context leakage across
+/// concurrent GCD operations.
+public protocol TraceContext: AnyObject {}
+
+/// Which cache tier produced the span.
+public enum CacheLayer: String {
+    case memory  = "memory"
+    case disk    = "disk"
+    case unified = "unified"  // Cache facade that spans both tiers
+}
+
+/// Logical operation recorded by the span.
+public enum CacheOperation: String {
+    case get       = "cache.get"
+    case set       = "cache.set"
+    case remove    = "cache.remove"
+    case removeAll = "cache.removeAll"
+    case trim      = "cache.trim"
+}
+
+/// Outcome of the operation, recorded when the span ends.
+public enum CacheOutcome: String {
+    case hit      = "hit"       // read: key found
+    case miss     = "miss"      // read: key absent
+    case set      = "set"       // write completed
+    case removed  = "removed"   // key existed and was deleted
+    case evicted  = "evicted"   // entry(s) expelled by a trim/eviction
+    case notFound = "notFound"  // remove called but key was absent
+}
+
+/// Dimension used by a trim operation.
+public enum TrimDimension {
+    case count(UInt)
+    case cost(UInt)
+    case age(TimeInterval)
+}
+
+/// Immutable snapshot of span attributes. Passed to both `startSpan` and
+/// `endSpan`; the `outcome` and `byteSize` fields are only meaningful when
+/// passed to `endSpan` (they may be placeholder values at start time).
+public struct CacheSpanAttributes {
+    /// Name of the cache instance (e.g. "defaultTrackCache").
+    public let cacheName: String
+    /// Which tier of the cache hierarchy produced this span.
+    public let layer: CacheLayer
+    /// Logical operation.
+    public let operation: CacheOperation
+    /// Cache key. Nil for removeAll and trim operations.
+    public let key: String?
+    /// Operation outcome. A placeholder value is used at span-start time.
+    public let outcome: CacheOutcome
+    /// Byte size of the involved object(s). Nil when not applicable.
+    public let byteSize: UInt?
+    /// Non-nil only for trim spans.
+    public let trimDimension: TrimDimension?
+
+    public init(cacheName: String, layer: CacheLayer, operation: CacheOperation,
+                key: String?, outcome: CacheOutcome, byteSize: UInt?,
+                trimDimension: TrimDimension?) {
+        self.cacheName = cacheName
+        self.layer = layer
+        self.operation = operation
+        self.key = key
+        self.outcome = outcome
+        self.byteSize = byteSize
+        self.trimDimension = trimDimension
+    }
+}
+
+// MARK: - TraceBackend protocol
+
+/// Implement this protocol to connect Track to any distributed tracing system
+/// (OpenTelemetry, Datadog, Zipkin, …). The library never imports or links
+/// against any tracing SDK directly.
+///
+/// All methods may be called from any GCD queue; implementations must be
+/// thread-safe.
+public protocol TraceBackend: AnyObject {
+    /// Called before the operation executes. Return a new child `TraceContext`
+    /// representing this span, or `nil` to suppress all further callbacks for
+    /// this operation (the library will not call `endSpan` for a nil return).
+    func startSpan(named name: String, parent: TraceContext,
+                   attributes: CacheSpanAttributes) -> TraceContext?
+
+    /// Called after the operation completes, always outside any internal lock.
+    /// `span` is the value previously returned by `startSpan`.
+    /// `finalAttributes` carries the definitive outcome and byte size.
+    func endSpan(_ span: TraceContext, finalAttributes: CacheSpanAttributes,
+                 error: Error?)
+}
+
+// MARK: - NoOpTraceBackend
+
+/// Default backend. All methods are empty stubs. The Swift optimizer inlines
+/// the `_withSpan` fast-path (nil context check) so that callers who never
+/// provide a `traceContext` incur zero overhead.
+public final class NoOpTraceBackend: TraceBackend {
+    public static let shared = NoOpTraceBackend()
+    private init() {}
+
+    public func startSpan(named name: String, parent: TraceContext,
+                          attributes: CacheSpanAttributes) -> TraceContext? { nil }
+    public func endSpan(_ span: TraceContext, finalAttributes: CacheSpanAttributes,
+                        error: Error?) {}
+}
+
+// MARK: - TraceConfiguration
+
+/// Global configuration point for the tracing backend.
+/// Call `TraceConfiguration.configure(backend:)` once at app startup before
+/// any cache operations begin. Replacing the backend at runtime is
+/// supported but not recommended in production.
+public struct TraceConfiguration {
+    private static var _backend: TraceBackend = NoOpTraceBackend.shared
+    private static let _lock = DispatchSemaphore(value: 1)
+
+    /// Install a new tracing backend. Thread-safe.
+    public static func configure(backend: TraceBackend) {
+        _lock.wait()
+        _backend = backend
+        _lock.signal()
+    }
+
+    /// Current backend. Called at the start of every public cache method when
+    /// a trace context is provided.
+    internal static var backend: TraceBackend {
+        _lock.wait()
+        let b = _backend
+        _lock.signal()
+        return b
+    }
+}
+
+// MARK: - _withSpan helper
+
+/// Wraps a synchronous cache operation in a child span.
+///
+/// Fast path: when `context` is `nil`, `body` is called immediately with a
+/// nil child-span argument and the backend is never touched. The
+/// `@inline(__always)` attribute collapses this to a direct call in release
+/// builds.
+///
+/// When `context` is non-nil, the backend's `startSpan` is called. If
+/// `startSpan` returns `nil` (the backend chose to suppress this span),
+/// `body` still executes but `endSpan` is never called.
+///
+/// `body` receives the (optional) child span context so it can pass it to
+/// nested operations. It returns `(result, outcome, finalBytes)` which are
+/// used to build the final attributes for `endSpan`.
+@inline(__always)
+internal func _withSpan<T>(
+    named spanName: String,
+    operation: CacheOperation,
+    key: String?,
+    cacheName: String,
+    layer: CacheLayer,
+    byteSize: UInt? = nil,
+    trimDimension: TrimDimension? = nil,
+    context: TraceContext?,
+    body: (_ childSpan: TraceContext?) throws -> (result: T, outcome: CacheOutcome, finalBytes: UInt?)
+) rethrows -> T {
+    guard let parent = context else {
+        // Fast path — no tracing requested.
+        let (result, _, _) = try body(nil)
+        return result
+    }
+
+    let startAttrs = CacheSpanAttributes(
+        cacheName: cacheName, layer: layer, operation: operation,
+        key: key, outcome: .set,  // placeholder outcome, overwritten at end
+        byteSize: byteSize, trimDimension: trimDimension
+    )
+    let backend = TraceConfiguration.backend
+    let span = backend.startSpan(named: spanName, parent: parent, attributes: startAttrs)
+
+    do {
+        let (result, outcome, finalBytes) = try body(span)
+        if let span = span {
+            let endAttrs = CacheSpanAttributes(
+                cacheName: cacheName, layer: layer, operation: operation,
+                key: key, outcome: outcome,
+                byteSize: finalBytes ?? byteSize,
+                trimDimension: trimDimension
+            )
+            backend.endSpan(span, finalAttributes: endAttrs, error: nil)
+        }
+        return result
+    } catch {
+        if let span = span {
+            backend.endSpan(span, finalAttributes: startAttrs, error: error)
+        }
+        throw error
+    }
+}
